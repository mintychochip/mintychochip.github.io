---
import Layout from "../layouts/Layout.astro";
import Badges from "../components/CredlyBadges.vue";
import ProjectGrid from "../components/ProjectGrid.vue";
import Timeline from "../components/Timeline.vue";
import SectionHeading from "../components/SectionHeading.astro";

const CREDLY_ID: string = "justin-lo.dd591245";

interface Project {
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  url?: string;
  preview?: string;
}

const projects: Project[] = [
  {
    title: "Ink Language",
    description: "Core contributor to ink, a compiled scripting language for the modern VM. Building the language runtime, standard library, and tooling for game developers.",
    tags: ["Kotlin", "LLVM", "Compilers", "Game Dev"],
    repo: "https://github.com/inklang/ink",
    url: "https://inklang.org",
    preview: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&auto=format&fit=crop",
  },
  {
    title: "Lectern - Package Registry",
    description: "Built and deployed the official package registry for the Ink programming language. Astro-based frontend with Supabase backend, deployed on Vercel.",
    tags: ["Astro", "Supabase", "TypeScript", "Vercel"],
    repo: "https://github.com/inklang/lectern",
    url: "https://lectern.inklang.org",
    preview: "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=800&auto=format&fit=crop",
  },
  {
    title: "OpenClaw Agent",
    description: "Active contributor to OpenClaw, an AI agent framework. Building skills for GitHub automation, Trello integration, and developer productivity tools.",
    tags: ["TypeScript", "AI Agents", "Node.js", "Automation"],
    repo: "https://github.com/openclaw/openclaw",
    url: "https://openclaw.ai",
    preview: "https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&auto=format&fit=crop",
  },
  {
    title: "ModularJobs",
    description: "Minecraft Paper plugin providing a modular, highly-configurable jobs system. Features level progression, economy integration, and specializations with 900+ downloads on Modrinth.",
    tags: ["Java", "Minecraft", "Paper API", "SQLite"],
    repo: "https://github.com/mintychochip/ModularJobs",
    url: "https://modrinth.com/plugin/modularjobs",
    preview: "https://images.unsplash.com/photo-1587573089734-599d584d65e4?w=800&auto=format&fit=crop",
  },
  {
    title: "Kitsune - Semantic Search",
    description: "Semantic search engine for block game assets. Uses vector embeddings and similarity matching to find related game content across massive datasets.",
    tags: ["Python", "Machine Learning", "Vector DB", "NLP"],
    repo: "https://github.com/mintychochip/Kitsune",
    preview: "https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?w=800&auto=format&fit=crop",
  },
  {
    title: "Economy Package for Ink",
    description: "Single-currency economy system for Inklang Minecraft servers. SQLite-backed with built-in functions for PaperMC, supporting thousands of concurrent players.",
    tags: ["Kotlin", "Minecraft", "SQLite", "Ink"],
    repo: "https://github.com/inklang/economy",
    preview: "https://images.unsplash.com/photo-1579621970563-ebec7560ff3e?w=800&auto=format&fit=crop",
  },
  {
    title: "Brushogun - Mob AI Library",
    description: "Declarative mob behavior library for Inklang. Define equipment, drops, skills, and event-driven AI for complex mob interactions in Minecraft.",
    tags: ["Kotlin", "Game AI", "Ink", "Event-Driven"],
    repo: "https://github.com/inklang/brushogun",
    preview: "https://images.unsplash.com/photo-1511512578047-dfb367046420?w=800&auto=format&fit=crop",
  },
  {
    title: "Backflow Monitor",
    description: "Real-time monitoring system for backflow prevention devices. IoT integration with alerting and compliance tracking for water systems.",
    tags: ["Python", "IoT", "Monitoring", "AWS"],
    repo: "https://github.com/mintychochip/backflow_monitor",
    preview: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&auto=format&fit=crop",
  },
  {
    title: "QuickQR - QR Code Generator",
    description: "Pay-as-you-go QR code generator with analytics and custom styling. Frontend built with modern web technologies.",
    tags: ["TypeScript", "React", "API Design", "Analytics"],
    repo: "https://github.com/mintychochip/quickqr-frontend",
    preview: "https://images.unsplash.com/photo-1595079676339-1534801ad6cf?w=800&auto=format&fit=crop",
  },
  {
    title: "VS Code Extension for Ink",
    description: "Official VS Code extension for the Ink programming language. Syntax highlighting, linting, code completion, and Language Server Protocol support.",
    tags: ["TypeScript", "VS Code", "LSP", "Developer Tools"],
    repo: "https://github.com/inklang/vscode-extension",
    preview: "https://images.unsplash.com/photo-1617042375876-a13e36732a04?w=800&auto=format&fit=crop",
  },
];

interface TimelineItem {
  year: string;
  date: string;
  title: string;
  description: string;
  image?: string;
  tags?: string[];
}

const timelineItems: TimelineItem[] = [
  {
    year: "2026",
    date: "Spring 2026",
    title: "Core Team - Ink Programming Language",
    description: "Joined the core team of inklang, a compiled scripting language for game development. Contributing to the language runtime, package ecosystem, and developer tooling. Led development of Lectern, the official package registry.",
    image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&auto=format&fit=crop",
    tags: ["Kotlin", "LLVM", "Open Source", "Language Design"],
  },
  {
    year: "2026",
    date: "Winter 2026",
    title: "OpenClaw Contributor",
    description: "Active contributor to OpenClaw AI agent framework. Building automation skills for GitHub, Trello, and developer productivity. Implemented autonomous issue resolution and PR creation systems.",
    image: "https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&auto=format&fit=crop",
    tags: ["AI Agents", "TypeScript", "Automation", "Open Source"],
  },
  {
    year: "2025",
    date: "Fall 2025",
    title: "Teaching Assistant - Data Structures",
    description: "Selected as TA for CS 311 Data Structures. Mentored 80+ students in algorithms, data structures, and problem-solving. Hosted weekly coding labs and office hours. Developed curriculum materials still used today.",
    image: "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=800&auto=format&fit=crop",
    tags: ["Teaching", "Algorithms", "Mentorship", "Leadership"],
  },
  {
    year: "2025",
    date: "Summer 2025",
    title: "Software Engineering Intern",
    description: "Interned at a Bakersfield tech startup, developing full-stack web applications. Built REST APIs, implemented authentication systems, and deployed to AWS. Gained experience with agile development and CI/CD pipelines.",
    image: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800&auto=format&fit=crop",
    tags: ["Full Stack", "AWS", "Agile", "REST API"],
  },
  {
    year: "2024",
    date: "Fall 2024",
    title: "Minecraft Plugin Development",
    description: "Started developing Minecraft Paper plugins, eventually reaching 1,000+ total downloads. Built ModularJobs, a highly-configurable jobs system with 900+ downloads. Learned Java, game development, and community management.",
    image: "https://images.unsplash.com/photo-1587573089734-599d584d65e4?w=800&auto=format&fit=crop",
    tags: ["Java", "Game Dev", "Community", "Open Source"],
  },
  {
    year: "2024",
    date: "Spring 2024",
    title: "Machine Learning Research",
    description: "Conducted independent research on semantic search and vector embeddings. Built Kitsune, a semantic search engine for game assets. Presented findings at the CSUB Undergraduate Research Symposium.",
    image: "https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?w=800&auto=format&fit=crop",
    tags: ["Machine Learning", "Research", "NLP", "Python"],
  },
  {
    year: "2023",
    date: "Fall 2023",
    title: "ACM Club Leadership",
    description: "Became an active leader in the ACM chapter and coding club. Organized hackathons, hosted tech talks, and mentored underclassmen. Built lasting connections with fellow developers and industry professionals.",
    image: "https://images.unsplash.com/photo-1515187029135-18ee286d815b?w=800&auto=format&fit=crop",
    tags: ["Leadership", "Community", "Networking", "Hackathons"],
  },
  {
    year: "2022",
    date: "Fall 2022",
    title: "Declared Computer Science Major",
    description: "After taking CS 101, knew this was my path. Declared Computer Science and dove into programming. Built first real projects, learned multiple languages, and discovered passion for open source development.",
    image: "https://images.unsplash.com/photo-1607799279861-4dd421887fb3?w=800&auto=format&fit=crop",
    tags: ["Programming", "Java", "Problem Solving", "Discovery"],
  },
  {
    year: "2021",
    date: "Fall 2021",
    title: "Started at CSU Bakersfield",
    description: "Began journey at California State University, Bakersfield. Nervous but excited to explore computer science. This university would shape my career, introduce me to amazing mentors, and set me on the path to becoming a software engineer.",
    image: "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?w=800&auto=format&fit=crop",
    tags: ["Freshman Year", "New Beginnings", "CSUB"],
  },
];
---

<Layout>
